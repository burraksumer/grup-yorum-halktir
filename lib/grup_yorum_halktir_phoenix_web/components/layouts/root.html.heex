<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />

    <%!-- Primary Meta Tags (per-page assigns with safe home defaults) --%>
    <% title = assigns[:page_title] || "Grup Yorum Halktır!" %>
    <% doc_title =
      if assigns[:page_title],
        do: assigns[:page_title] <> " · Grup Yorum Halktır!",
        else: "Grup Yorum Halktır!" %>
    <.live_title>{doc_title}</.live_title>
    <% description =
      assigns[:meta_description] ||
        "Grup Yorum'un tüm albümlerine ve şarkılarına özgürce erişin. Sansüre ve erişim engellemelerine karşı direnişin sesi." %>
    <% canonical = assigns[:canonical_url] || "https://grupyorum.mulayim.app/" %>
    <% og_image =
      assigns[:og_image] ||
        "https://grupyorumr2.mulayim.app/albums/1987-siyrilip-gelen/cover.jpg" %>
    <% og_type = assigns[:og_type] || "website" %>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="Grup Yorum, müzik, türkü, direniş, sansür, halk müziği, müzik arşivi"
    />
    <meta name="author" content="Grup Yorum Halktır" />
    <link rel="canonical" href={canonical} />

    <%!-- Open Graph / Facebook --%>
    <meta property="og:type" content={og_type} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={og_image} />
    <meta property="og:locale" content="tr_TR" />

    <%!-- Twitter --%>
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={og_image} />

    <%!-- JSON-LD structured data (per-page, nil-safe) --%>
    <%= if json_ld = assigns[:json_ld] do %>
      <script type="application/ld+json">
        <%= Phoenix.HTML.raw(String.replace(Jason.encode!(json_ld), "</", "<\\/")) %>
      </script>
    <% end %>

    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script
      defer
      src="https://umami.mulayim.app/script.js"
      data-website-id="4e92fbeb-17f3-45a7-9f32-438a43927376"
    >
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
            // Use browser preference
            const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
            if (prefersDark) {
              document.documentElement.setAttribute("data-theme", "mono");
              document.documentElement.classList.add("dark");
            } else {
              document.documentElement.setAttribute("data-theme", "mono-light");
              document.documentElement.classList.remove("dark");
            }
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
            // Add/remove dark class based on theme
            if (theme === "mono") {
              document.documentElement.classList.add("dark");
            } else {
              document.documentElement.classList.remove("dark");
            }
          }
        };
        
        // Initialize theme on page load
        const savedTheme = localStorage.getItem("phx:theme");
        if (!savedTheme || savedTheme === "system") {
          // Use browser preference if no saved theme or system preference
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          if (prefersDark) {
            document.documentElement.setAttribute("data-theme", "mono");
            document.documentElement.classList.add("dark");
          } else {
            document.documentElement.setAttribute("data-theme", "mono-light");
            document.documentElement.classList.remove("dark");
          }
        } else {
          setTheme(savedTheme);
        }
        
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
        
        // Listen for system theme changes
        window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
          const currentTheme = localStorage.getItem("phx:theme");
          if (!currentTheme || currentTheme === "system") {
            if (e.matches) {
              document.documentElement.setAttribute("data-theme", "mono");
              document.documentElement.classList.add("dark");
            } else {
              document.documentElement.setAttribute("data-theme", "mono-light");
              document.documentElement.classList.remove("dark");
            }
          }
        });
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
